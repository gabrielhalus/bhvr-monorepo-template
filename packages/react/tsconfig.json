{
  "extends": "typescript-config/react.json",
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "rootDir": "src",
    "paths": {
      "~api/*": ["../../apps/api/src/*"],
      "~react/*": ["../react/src/*"],
      "~shared/*": ["../shared/src/*"]
    },
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "dist"
  },
  "references": [
    { "path": "../../apps/api" },
    { "path": "../shared" }
  ],
  "include": ["src", "../../apps/web/env.d.ts"],
  "exclude": ["node_modules", "dist"]
}
