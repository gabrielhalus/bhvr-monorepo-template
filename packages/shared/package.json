{
  "name": "shared",
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc -b",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "bun test __tests__ --env-file ../../.env.test",
    "test:coverage": "bun test __tests__ --coverage --env-file ../../.env.test",
    "drizzle:generate": "drizzle-kit generate --config=drizzle.config.cjs",
    "drizzle:migrate": "drizzle-kit migrate --config=drizzle.config.cjs",
    "drizzle:push": "drizzle-kit push --config=drizzle.config.cjs",
    "drizzle:studio": "drizzle-kit studio --config=drizzle.config.cjs",
    "bootstrap": "bun run scripts/bootstrap.ts",
    "reset-password": "bun run scripts/reset-password.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.2",
    "drizzle-zod": "^0.7.1",
    "i18next": "^25.5.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-fs-backend": "^2.6.0",
    "nanoid": "^5.1.5",
    "postgres": "^3.4.7",
    "react-i18next": "^16.0.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.8",
    "eslint-plugin-drizzle": "^0.2.3"
  }
}
