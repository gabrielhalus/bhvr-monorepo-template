{
  "$schema": "https://v2-8-11.turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "APP_ENV",
    "APP_HOST",
    "APP_PORT",
    "API_URL",
    "DATABASE_URL",
    "JWT_SECRET",
    "AUTH_URL",
    "SITE_URL",
    "VITE_API_URL",
    "VITE_AUTH_URL",
    "VITE_SITE_URL"
  ],
  "tasks": {
    "bootstrap": {
      "cache": false,
      "persistent": false
    },
    "build": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "reset-password": {
      "cache": false,
      "persistent": false
    },
    "test": {
      "dependsOn": ["^test"],
      "cache": false,
      "persistent": true
    },
    "drizzle:generate": {
      "cache": false,
      "dependsOn": ["^drizzle:generate"]
    },
    "drizzle:push": {
      "cache": false,
      "dependsOn": ["^drizzle:push"]
    },
    "drizzle:studio": {
      "cache": false,
      "persistent": true
    },
  }
}
