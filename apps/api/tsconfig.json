{
  "extends": "typescript-config/react.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "src",
    "paths": {
      "@/*": ["./src/*"],
      "~shared/*": ["../../packages/shared/src/*"],
      "~seeds": ["../../packages/shared/seeds"]
    },
    "types": ["bun", "node"],
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "dist"
  },
  "references": [
    { "path": "../../packages/shared" }
  ],
  "include": ["src", "./env.d.ts"]
}
