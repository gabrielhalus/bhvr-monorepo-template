{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "concurrently \"bun run --watch src/index.ts\" \"tsc --watch\"",
    "build": "tsc -b",
    "lint": "eslint . --max-warnings 0",
    "start": "bun run src/index.ts",
    "check-types": "tsc --noEmit",
    "test": "bun test __tests__ --env-file ../../.env.test",
    "test:coverage": "bun test __tests__ --coverage --env-file ../../.env.test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1065.0",
    "@hono/zod-validator": "^0.7.0",
    "arctic": "^3.7.0",
    "bullmq": "^5.79.3",
    "croner": "^10.0.1",
    "hono": "4.11.3",
    "ioredis": "5.10.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "resend": "^6.1.1",
    "shared": "workspace:*"
  }
}
