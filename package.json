{
  "name": "bunstack",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "clean": "rm -rf packages/*/dist packages/*/.turbo packages/*/tsconfig.tsbuildinfo apps/*/dist apps/*/.turbo apps/*/tsconfig.tsbuildinfo",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "lint": "turbo run lint --",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "drizzle:generate": "turbo run drizzle:generate --filter=shared",
    "drizzle:push": "turbo run drizzle:push --filter=shared",
    "drizzle:studio": "turbo run drizzle:studio --filter=shared",
    "bootstrap": "turbo run bootstrap --filter=shared",
    "reset-password": "turbo run reset-password --filter=shared"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "baseline-browser-mapping": "^2.9.11",
    "concurrently": "^9.2.1",
    "eslint": "^9.28.0",
    "eslint-config": "workspace:*",
    "rimraf": "^6.1.2",
    "shadcn": "^3.6.3",
    "turbo": "^2.8.11",
    "typescript": "5.8.2",
    "typescript-config": "workspace:*"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.2.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "i18next": "^25.5.3",
    "react-i18next": "^16.0.0",
    "varlock": "^0.6.3",
    "zod": "^4.1.11"
  }
}
